{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Historical Absolute Poverty Trajectories by State",
  "data": {
    "url": "hh_poverty_state.csv",
    "format": {"type": "csv"}
  },
  "facet": {
    "field": "state",
    "type": "nominal",
    "columns": 4,
    "title": null
  },
  "spec": {
    "width": 100,
    "height": 70,
    "layer": [
      {
        "mark": {
          "type": "area",
          "line": {"color": "#023e8a", "width": 1.5},
          "color": "#e0f2fe"
        },
        "encoding": {
          "x": {
            "field": "date",
            "type": "temporal",
            "axis": {
              "format": "%y", 
              "title": null,
              "tickCount": 3
            }
          },
          "y": {
            "field": "poverty_absolute",
            "type": "quantitative",
            "axis": {
              "title": null,
              "tickCount": 3
            }
          }
        }
      },
      {
        "mark": {
          "type": "rule",
          "color": "#e67e22",
          "strokeDash": [3, 3]
        },
        "encoding": {
          "y": {"datum": 10}
        }
      }
    ]
  },
  "resolve": {
    "scale": {
      "x": "independent",
      "y": "independent"
    }
  }
}