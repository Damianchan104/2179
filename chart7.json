{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 800,
  "height": 500,
  "title": "Historical Absolute Poverty Range & Volatility Bounds by State",
  "data": {
    "url": "hh_poverty_state.csv",
    "format": {"type": "csv"}
  },
  "transform": [
    {
      "filter": "datum.poverty_absolute != null"
    }
  ],
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "sort": {"op": "max", "field": "poverty_absolute", "order": "descending"},
      "axis": {
        "labelPadding": 10
      }
    }
  },
  "layer": [
    {
      "mark": "rule",
      "encoding": {
        "x": {
          "aggregate": "min",
          "field": "poverty_absolute",
          "type": "quantitative",
          "title": "Poverty Rate Range Spreads (%)"
        },
        "x2": {
          "aggregate": "max",
          "field": "poverty_absolute"
        },
        "color": {"value": "#cbd5e1"},
        "strokeWidth": {"value": 4}
      }
    },
    {
      "mark": {"type": "point", "size": 80, "filled": true},
      "encoding": {
        "x": {
          "aggregate": "min",
          "field": "poverty_absolute",
          "type": "quantitative"
        },
        "color": {"value": "#2980b9"}
      }
    },
    {
      "mark": {"type": "point", "size": 80, "filled": true},
      "encoding": {
        "x": {
          "aggregate": "max",
          "field": "poverty_absolute",
          "type": "quantitative"
        },
        "color": {"value": "#e67e22"}
      }
    }
  ]
}