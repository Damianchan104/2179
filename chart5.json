{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 280,
  "data": {
    "url": "hh_poverty_state.csv",
    "format": {"type": "csv", "parse": {"date": "string"}}
  },
  "transform": [
    {
      "filter": "datum.date === '2022-01-01'"
    },
    {
      "calculate": "datum.poverty_absolute - 6.2",
      "as": "deviation"
    }
  ],
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "state",
      "type": "nominal",
      "sort": "-y",
      "axis": {"labelAngle": 45, "title": null}
    },
    "y": {
      "field": "deviation",
      "type": "quantitative",
      "axis": {"title": "Variance Distance (%)"}
    },
    "color": {
      "condition": {
        "test": "datum.deviation > 0",
        "value": "#d73027"
      },
      "value": "#4575b4"
    },
    "tooltip": [
      {"field": "state", "type": "nominal"},
      {"field": "poverty_absolute", "type": "quantitative"},
      {"field": "deviation", "type": "quantitative", "format": "+.1f"}
    ]
  }
}