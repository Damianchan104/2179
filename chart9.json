{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 400,
  "height": 400,
  "title": {
    "text": "Comparative Analysis: Absolute vs. Relative Poverty (2022)",
    "subtitle": "A diverging structure evaluating regional household baseline disparities",
    "anchor": "start",
    "offset": 20
  },
  "data": {
    "url": "hh_poverty_state.csv",
    "format": {"type": "csv", "parse": {"date": "string"}}
  },
  "params": [
    {
      "name": "Hardcore_Floor",
      "value": 0,
      "bind": {
        "input": "range",
        "min": 0,
        "max": 1.2,
        "step": 0.1,
        "name": "Min Hardcore Floor %: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.date === '2022-01-01'"},
    {"filter": "datum.poverty_hardcore >= Hardcore_Floor"},
    {"calculate": "-datum.poverty_absolute", "as": "abs_neg"}
  ],
  "layer": [
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "axis": {"title": null}, "sort": "-x"},
        "x": {
          "field": "abs_neg", 
          "type": "quantitative",
          "axis": {"title": "← Absolute (%) | Relative (%) →", "format": "~s"}
        },
        "color": {
          "datum": "Absolute Poverty",
          "scale": {
            "domain": ["Absolute Poverty", "Relative Poverty"],
            "range": ["#185FA5", "#1D9E75"]
          },
          "legend": {
            "title": "Poverty Metrics",
            "orient": "right",
            "offset": 15
          }
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "poverty_absolute", "title": "Absolute %", "format": ".1f"}
        ]
      }
    },
    {
      "mark": {"type": "bar"},
      "encoding": {
        "y": {"field": "state", "type": "nominal", "sort": "-x"},
        "x": {"field": "poverty_relative", "type": "quantitative"},
        "color": {
          "datum": "Relative Poverty"
        },
        "tooltip": [
          {"field": "state", "title": "State"},
          {"field": "poverty_relative", "title": "Relative %", "format": ".1f"}
        ]
      }
    }
  ]
}